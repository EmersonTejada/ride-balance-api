{
  "name": "ride-balance-api",
  "version": "1.0.0",
  "description": "API Ride Balance",
  "main": "dist/app.js",
  "scripts": {
    "build": "npx prisma generate && tsc",
    "start": "node ./dist/server.js",
    "dev": "nodemon",
    "test": "npx prisma generate && tsc --noEmit && NODE_OPTIONS='--experimental-vm-modules' jest",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:stop": "docker compose -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:logs:api": "docker compose -f docker-compose.dev.yml logs -f api",
    "docker:logs:db": "docker compose -f docker-compose.dev.yml logs -f db"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "nodemon": "^3.1.10",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
